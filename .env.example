# ─── Required ────────────────────────────────────────────────────────────────

# OpenAI API key for summarization
OPENAI_API_KEY=

# Azure AD app registration credentials for Microsoft Graph
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_TENANT_ID=

# Sender mailbox address (must have Graph Mail.Send Application permission)
EMAIL_FROM=

# Shared secret sent by Zapier in the X-Webhook-Secret header
WEBHOOK_SECRET=

# ─── Optional (defaults shown) ───────────────────────────────────────────────

# CC recipient on all recap emails (default: bill.johnson@scribendi.com)
# EMAIL_CC=bill.johnson@scribendi.com

# Maximum transcript length in characters before truncation (default: 100000)
# MAX_TRANSCRIPT_CHARS=100000

# OpenAI model used for summarization (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# Host and port to bind the webhook server
# WEBHOOK_HOST=0.0.0.0
# WEBHOOK_PORT=8000

# Python logging level (default: INFO)
# LOG_LEVEL=INFO
